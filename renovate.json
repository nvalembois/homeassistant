{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "customManagers:dockerfileVersions",
    "docker:pinDigests",
    ":automergeDigest",
    ":automergeMinor"
  ],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "matchFileNames": ["Dockerfile"],
      "groupName": "homeassistant"
    },
    {
      "matchDatasources": ["github-tags"],
      "groupName": "githubCi"
    }    
  ]
}
